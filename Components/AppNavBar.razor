@using EduConnect.Models
@using EduConnect.Services
@inject AuthStateService AuthState
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-mortarboard-fill me-2"></i>
            EduConnect
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                @if (AuthState.State.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link @GetActiveClass(GetDashboardLink())" href="@GetDashboardLink()">
                            <i class="bi bi-speedometer2 me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @GetActiveClass("/courses")" href="/courses">
                            <i class="bi bi-search me-1"></i> Course Catalog
                        </a>
                    </li>
                    @if (AuthState.State.IsAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/admin/students")" href="/admin/students">
                                <i class="bi bi-people me-1"></i> Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/admin/courses")" href="/admin/courses">
                                <i class="bi bi-journal-text me-1"></i> Courses
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/admin/reports")" href="/admin/reports">
                                <i class="bi bi-bar-chart me-1"></i> Reports
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/admin/notifications")" href="/admin/notifications">
                                <i class="bi bi-bell me-1"></i> Broadcast
                            </a>
                        </li>
                    }
                    else if (AuthState.State.IsFaculty)
                    {
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/faculty/courses")" href="/faculty/courses">
                                <i class="bi bi-journal-text me-1"></i> My Courses
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/faculty/grades")" href="/faculty/grades">
                                <i class="bi bi-pencil-square me-1"></i> Grade Submission
                            </a>
                        </li>
                    }
                    else if (AuthState.State.IsStudent)
                    {
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/student/enroll")" href="/student/enroll">
                                <i class="bi bi-plus-circle me-1"></i> Enroll
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @GetActiveClass("/student/grades")" href="/student/grades">
                                <i class="bi bi-card-checklist me-1"></i> My Grades
                            </a>
                        </li>
                    }
                    
                    <li class="nav-item">
                        <a class="nav-link @GetActiveClass("/notifications")" href="/notifications">
                            <i class="bi bi-bell me-1"></i> Notifications
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link @GetActiveClass("/")" href="/">
                            <i class="bi bi-house me-1"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @GetActiveClass("/courses")" href="/courses">
                            <i class="bi bi-search me-1"></i> Course Catalog
                        </a>
                    </li>
                }
            </ul>

            <ul class="navbar-nav">
                @if (AuthState.State.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-2"></i>
                            <span class="me-2">@AuthState.State.CurrentUser?.FullName</span>
                            <span class="badge bg-light text-dark">@AuthState.State.Role</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="@GetDashboardLink()">
                                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/profile">
                                    <i class="bi bi-person me-2"></i> My Profile
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="/logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-light btn-sm me-2" href="/login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-light btn-sm" href="/register">
                            <i class="bi bi-person-plus me-1"></i> Register
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    private string GetActiveClass(string path)
    {
        var currentUri = Nav.Uri;
        return currentUri.Contains(path) ? "active fw-bold" : "";
    }

    private string GetDashboardLink()
    {
        if (!AuthState.State.IsAuthenticated)
            return "/";

        return AuthState.State.CurrentUser switch
        {
            Admin => "/admin/dashboard",
            Faculty => "/faculty/dashboard",
            Student => "/student/dashboard",
            _ => "/"
        };
    }
}