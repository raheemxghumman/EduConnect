@using EduConnect.Models
@using EduConnect.Services
@implements IDisposable
@inject AuthStateService AuthState
@inject NavigationManager Nav

@if (AuthState.State.IsAuthenticated)
{
<nav class="navbar navbar-expand-lg">
    <div class="container-fluid" style="max-width: 1400px; padding-left: clamp(1rem, 3vw, 2rem); padding-right: clamp(1rem, 3vw, 2rem);">
        <a class="navbar-brand" href="@DashboardLink">
            <span style="position:absolute;left:-9999px;">EC</span>
            EduConnect
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @ActiveClass(DashboardLink)" href="@DashboardLink">
                        <i class="bi bi-speedometer2 me-1"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @ActiveClass("/courses")" href="/courses">
                        <i class="bi bi-journal-text me-1"></i> Courses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @ActiveClass("/notifications")" href="/notifications">
                        <i class="bi bi-bell me-1"></i> Notifications
                    </a>
                </li>
                @if (AuthState.State.IsAdmin)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-shield-lock me-1"></i> Admin
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/admin/students"><i class="bi bi-people me-2"></i>Students</a></li>
                            <li><a class="dropdown-item" href="/admin/courses"><i class="bi bi-book me-2"></i>Courses</a></li>
                            <li><a class="dropdown-item" href="/admin/reports/grades"><i class="bi bi-bar-chart me-2"></i>Grade Report</a></li>
                            <li><a class="dropdown-item" href="/admin/notifications"><i class="bi bi-megaphone me-2"></i>Broadcast</a></li>
                        </ul>
                    </li>
                }
                @if (AuthState.State.IsFaculty)
                {
                    <li class="nav-item">
                        <a class="nav-link @ActiveClass("/faculty/courses")" href="/faculty/courses">
                            <i class="bi bi-collection me-1"></i> My Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @ActiveClass("/faculty/grades")" href="/faculty/grades">
                            <i class="bi bi-pencil-square me-1"></i> Submit Grades
                        </a>
                    </li>
                }
                @if (AuthState.State.IsStudent)
                {
                    <li class="nav-item">
                        <a class="nav-link @ActiveClass("/student/enroll")" href="/student/enroll">
                            <i class="bi bi-plus-circle me-1"></i> Enroll
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @ActiveClass("/student/grades")" href="/student/grades">
                            <i class="bi bi-award me-1"></i> My Grades
                        </a>
                    </li>
                }
            </ul>

            <div class="navbar-user">
                <NotificationBell />
                <a href="/profile" class="user-name d-none d-md-inline" title="View profile">
                    @AuthState.State.CurrentUser!.FullName
                </a>
                <span class="role-pill">@AuthState.State.Role</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="Logout" title="Sign out">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="d-none d-lg-inline ms-1">Logout</span>
                </button>
            </div>
        </div>
    </div>
</nav>
}

@code {
    private string DashboardLink => AuthState.State.CurrentUser switch
    {
        global::EduConnect.Models.Admin   => "/admin/dashboard",
        global::EduConnect.Models.Faculty => "/faculty/dashboard",
        global::EduConnect.Models.Student => "/student/dashboard",
        _ => "/login"
    };

    private string ActiveClass(string href)
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        return string.Equals(path.TrimEnd('/'), href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    protected override void OnInitialized()
    {
        AuthState.OnAuthChanged += Refresh;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void Logout()
    {
        AuthState.Logout();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthState.OnAuthChanged -= Refresh;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
