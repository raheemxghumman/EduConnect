@page "/login"
@layout EmptyLayout
@using EduConnect.Services
@using EduConnect.Models
@inject AuthStateService AuthState
@inject NavigationManager Nav

<AuthGuard RequireAuth="false">
    <div class="auth-shell">
        <div class="auth-card">
            <div class="auth-header">
                <h4><i class="bi bi-mortarboard-fill me-2"></i>Welcome back</h4>
                <p>Sign in to your EduConnect account</p>
            </div>
            <div class="auth-body">
                <div class="mb-3">
                    <label for="email" class="form-label">
                        <i class="bi bi-envelope me-1 text-muted"></i> Email address
                    </label>
                    <input id="email" type="email"
                           @bind="loginModel.Email" @bind:event="oninput"
                           @onblur="() => emailTouched = true"
                           class="form-control @(emailTouched && string.IsNullOrEmpty(loginModel.Email) ? "is-invalid" : "")"
                           placeholder="you@educonnect.edu"
                           autocomplete="email" />
                    @if (emailTouched && string.IsNullOrEmpty(loginModel.Email))
                    {
                        <div class="invalid-feedback">Email is required</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">
                        <i class="bi bi-lock me-1 text-muted"></i> Password
                    </label>
                    <input id="password" type="password"
                           @bind="loginModel.Password" @bind:event="oninput"
                           @onblur="() => passwordTouched = true"
                           class="form-control @(passwordTouched && string.IsNullOrEmpty(loginModel.Password) ? "is-invalid" : "")"
                           placeholder="Enter your password"
                           autocomplete="current-password" />
                    @if (passwordTouched && string.IsNullOrEmpty(loginModel.Password))
                    {
                        <div class="invalid-feedback">Password is required</div>
                    }
                </div>

                <button type="button" class="btn btn-primary w-100 btn-lg mb-3"
                        disabled="@isLoggingIn" @onclick="HandleLogin">
                    @if (isLoggingIn)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Signing in…</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Sign in</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="auth-link">
                    Don't have an account? <a href="/register">Create one →</a>
                </div>

                <hr />

                <div class="alert alert-info" style="margin-bottom:0;">
                    <div>
                        <div class="fw-bold mb-2">
                            <i class="bi bi-info-circle"></i> Demo credentials
                        </div>
                        <div style="font-size:.85rem; line-height:1.7;">
                            <div><strong>Admin</strong> · admin@edu.pk / admin123</div>
                            <div><strong>Faculty</strong> · ayesha@edu.pk / faculty123</div>
                            <div><strong>Student</strong> · wania@student.edu.pk / student123</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</AuthGuard>

@code {
    private LoginModel loginModel = new();
    private bool isLoggingIn = false;
    private string? errorMessage;
    private bool emailTouched = false;
    private bool passwordTouched = false;

    private class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleLogin()
    {
        emailTouched = true;
        passwordTouched = true;

        if (string.IsNullOrEmpty(loginModel.Email) || string.IsNullOrEmpty(loginModel.Password))
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        isLoggingIn = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            await Task.Delay(300);
            var success = AuthState.Login(loginModel.Email, loginModel.Password);
            if (success)
            {
                Nav.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                errorMessage = "Invalid email or password. Please check your credentials.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoggingIn = false;
            StateHasChanged();
        }
    }
}
