@page "/faculty/dashboard"
@inject ICourseService CourseSvc
@inject AuthStateService AuthState

<AuthGuard RequiredRole="Faculty">
    <div class="role-header">
        <div class="d-flex align-items-center">
            <div class="role-icon"><i class="bi bi-person-badge text-success"></i></div>
            <div class="ms-3">
                <h2 class="mb-1">Faculty Dashboard</h2>
                <p class="mb-0 text-muted">
                    Welcome, <strong>@AuthState.State.CurrentUser?.FullName</strong> ·
                    your assigned courses & grade tools
                </p>
            </div>
        </div>
    </div>

    @{
        var myCourses = CourseSvc.GetForFaculty(AuthState.State.CurrentUser!.Id).ToList();
        var totalEnrolled = myCourses.Sum(c => c.Enrolled.Count);
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="stat-icon"><i class="bi bi-collection-fill"></i></div>
                    <div class="stat-label">Assigned courses</div>
                    <div class="stat-value">@myCourses.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="stat-icon" style="background:#dcfce7;color:var(--ec-success);"><i class="bi bi-people-fill"></i></div>
                    <div class="stat-label">Students enrolled</div>
                    <div class="stat-value">@totalEnrolled</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="stat-icon" style="background:#fef3c7;color:#d97706;"><i class="bi bi-clock-history"></i></div>
                    <div class="stat-label">Credit hours</div>
                    <div class="stat-value">@myCourses.Sum(c => c.CreditHours)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="btn btn-primary" href="/faculty/grades">
            <i class="bi bi-pencil-square"></i> Submit grades
        </a>
        <a class="btn btn-outline-primary" href="/faculty/courses">
            <i class="bi bi-collection"></i> View all my courses
        </a>
    </div>

    <h4 class="mb-3" style="font-size:1.05rem;color:var(--ec-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em;">My courses</h4>
    @if (!myCourses.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i>
            <span>You have no courses assigned yet.</span>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var c in myCourses)
            {
                <div class="col"><CourseCard Course="c" /></div>
            }
        </div>
    }
</AuthGuard>
