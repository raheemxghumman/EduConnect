@page "/admin/students/edit/{Id:guid}"
@inject IStudentService StudentSvc
@inject NavigationManager Nav

<AuthGuard RequiredRole="Admin">
    @if (_student == null)
    {
        <AlertBox Message="Student not found." Type="AlertBox.AlertType.Error" />
    }
    else
    {
        <div class="role-header">
            <div class="d-flex align-items-center">
                <div class="role-icon"><i class="bi bi-pencil-square"></i></div>
                <div class="ms-3">
                    <h2 class="mb-1">Edit Student</h2>
                    <p class="mb-0 text-muted">@_student.FullName · @_student.Email</p>
                </div>
            </div>
        </div>

        <AlertBox Message="@_message" Type="@_alert" />

        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Full name</label>
                        <input class="form-control" @bind="_student.FullName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input class="form-control" @bind="_student.Email" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Semester</label>
                        <select class="form-select" @bind="_student.Semester">
                            @for (int i = 1; i <= 8; i++) { <option value="@i">Semester @i</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">CGPA</label>
                        <input type="number" step="0.01" class="form-control" @bind="_student.CGPA" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Password</label>
                        <input class="form-control" @bind="_student.PasswordHash" />
                    </div>
                    <div class="col-12 d-flex gap-2 mt-4">
                        <button class="btn btn-primary" @onclick="Update">
                            <i class="bi bi-check2-circle"></i> Update
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="Back">
                            <i class="bi bi-arrow-left"></i> Back
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</AuthGuard>

@code {
    [Parameter] public Guid Id { get; set; }
    global::EduConnect.Models.Student? _student;
    string? _message;
    AlertBox.AlertType _alert = AlertBox.AlertType.Info;

    protected override void OnInitialized()
    {
        var s = StudentSvc.GetById(Id);
        if (s != null)
            _student = new global::EduConnect.Models.Student
            {
                Id = s.Id, FullName = s.FullName, Email = s.Email,
                PasswordHash = s.PasswordHash, Semester = s.Semester, CGPA = s.CGPA,
                Enrollments = s.Enrollments, Grades = s.Grades
            };
    }

    void Back() => Nav.NavigateTo("/admin/students");
    void Update()
    {
        try
        {
            if (_student != null) StudentSvc.Update(_student);
            _message = "Student updated.";
            _alert = AlertBox.AlertType.Success;
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _alert = AlertBox.AlertType.Error;
        }
    }
}
