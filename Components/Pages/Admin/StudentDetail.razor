@page "/admin/students/{Id:guid}"
@inject IStudentService StudentSvc
@inject NavigationManager Nav

<AuthGuard RequiredRole="Admin">
    @if (_student == null)
    {
        <AlertBox Message="Student not found." Type="AlertBox.AlertType.Error" />
    }
    else
    {
        <button class="btn btn-outline-secondary mb-3" @onclick="Back">
            <i class="bi bi-arrow-left"></i> Back to students
        </button>

        <div class="role-header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle d-flex align-items-center justify-content-center rounded-circle text-white"
                         style="width:64px;height:64px;font-size:1.4rem;">
                        @Initials(_student.FullName)
                    </div>
                    <div class="ms-3">
                        <h2 class="mb-1">@_student.FullName</h2>
                        <div class="text-muted"><i class="bi bi-envelope"></i> @_student.Email</div>
                    </div>
                </div>
                <a class="btn btn-primary" href="/admin/students/edit/@_student.Id">
                    <i class="bi bi-pencil"></i> Edit student
                </a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100"><div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Semester</div>
                    <div class="fs-4 fw-bold">@_student.Semester</div>
                </div></div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100"><div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">CGPA</div>
                    <div class="fs-4 fw-bold text-success">@_student.CGPA.ToString("0.00")</div>
                </div></div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100"><div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Enrolled</div>
                    <div class="fs-4 fw-bold">@_student.Enrollments.Count</div>
                </div></div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100"><div class="card-body">
                    <div class="text-muted small text-uppercase fw-bold">Avg. marks</div>
                    <div class="fs-4 fw-bold">@(_student.Grades.Any() ? _student.Grades.Average(g => g.Marks).ToString("F1") : "—")</div>
                </div></div>
            </div>
        </div>

        <h4 class="mb-3" style="font-size:1.05rem;color:var(--ec-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Enrollments</h4>
        @if (!_student.Enrollments.Any())
        {
            <div class="alert alert-info"><i class="bi bi-info-circle"></i><span>No enrollments yet.</span></div>
        }
        else
        {
            <div class="list-group mb-4">
                @foreach (var c in _student.Enrollments.OrderBy(c => c.Title))
                {
                    <div class="list-group-item">
                        <div class="fw-semibold">@c.Code</div>
                        <div class="text-muted small">@c.Title</div>
                    </div>
                }
            </div>
        }

        <h4 class="mb-3" style="font-size:1.05rem;color:var(--ec-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Grade history</h4>
        <GradeTable Grades="_student.Grades" />
    }
</AuthGuard>

@code {
    [Parameter] public Guid Id { get; set; }
    global::EduConnect.Models.Student? _student;

    protected override void OnInitialized() => _student = StudentSvc.GetById(Id);
    void Back() => Nav.NavigateTo("/admin/students");

    string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}".ToUpper() : parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
    }
}
