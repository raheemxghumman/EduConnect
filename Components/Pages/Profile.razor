@page "/profile"
@inject AuthStateService AuthState
@using EduConnect.Models

<AuthGuard>
    @{
        var user = AuthState.State.CurrentUser;
        var initials = GetInitials(user?.FullName ?? "");
    }

    <div class="role-header">
        <div class="d-flex align-items-center">
            <div class="role-icon"><i class="bi bi-person-circle"></i></div>
            <div class="ms-3">
                <h2 class="mb-1">My Profile</h2>
                <p class="mb-0 text-muted">Your account information</p>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex align-items-center mb-4 flex-wrap gap-3">
                <div class="avatar-circle d-flex align-items-center justify-content-center rounded-circle text-white"
                     style="width:80px;height:80px;font-size:1.75rem;">
                    @initials
                </div>
                <div>
                    <h3 class="mb-1">@user?.FullName</h3>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="text-muted"><i class="bi bi-envelope"></i> @user?.Email</span>
                        <span class="role-pill">@AuthState.State.Role</span>
                    </div>
                </div>
            </div>

            <hr />

            <div class="row g-3">
                @if (user is global::EduConnect.Models.Student s)
                {
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">Semester</div>
                        <div class="fs-5 fw-bold">@s.Semester</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">CGPA</div>
                        <div class="fs-5 fw-bold text-success">@s.CGPA.ToString("0.00")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase fw-bold">Enrolled courses</div>
                        <div class="fs-5 fw-bold">@s.Enrollments.Count</div>
                    </div>
                }
                else if (user is global::EduConnect.Models.Faculty f)
                {
                    <div class="col-md-6">
                        <div class="text-muted small text-uppercase fw-bold">Assigned courses</div>
                        <div class="fs-5 fw-bold">@f.AssignedCourses.Count</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small text-uppercase fw-bold">Role</div>
                        <div class="fs-5 fw-bold">Faculty member</div>
                    </div>
                }
                else if (user is global::EduConnect.Models.Admin)
                {
                    <div class="col-12">
                        <div class="text-muted small text-uppercase fw-bold">Privileges</div>
                        <div class="fs-6">Full system administration access — student, course, grade and broadcast management.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</AuthGuard>

@code {
    string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0].Substring(0, 2).ToUpper() : parts[0].ToUpper();
    }
}
