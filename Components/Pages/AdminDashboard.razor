@page "/admin/dashboard"
@using EduConnect.Services
@using EduConnect.Models
@inject AuthStateService AuthState
@inject IStudentService StudentService
@inject ICourseService CourseService
@inject IGradeService GradeService

<AuthGuard RequiredRole="Admin">
    <RoleLayout>
        <div class="container-fluid py-4">
            <div class="row mb-4">
                <div class="col">
                    <h2 class="fw-bold">
                        <i class="bi bi-shield-check me-2"></i>
                        Administrator Dashboard
                    </h2>
                    <p class="text-muted mb-0">
                        System overview and management controls.
                    </p>
                </div>
                <div class="col-auto">
                    <div class="d-flex align-items-center">
                        <span class="badge bg-danger fs-6 px-3 py-2">
                            <i class="bi bi-gear me-1"></i> System Admin
                        </span>
                    </div>
                </div>
            </div>

            <!-- System Stats -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm bg-gradient-primary text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-subtitle mb-1 opacity-75">Total Users</h6>
                                    <h3 class="card-title mb-0">@totalUsers</h3>
                                </div>
                                <i class="bi bi-people display-6 opacity-50"></i>
                            </div>
                            <a href="/admin/users" class="stretched-link text-white text-decoration-none small">
                                Manage users <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm bg-gradient-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-subtitle mb-1 opacity-75">Active Courses</h6>
                                    <h3 class="card-title mb-0">@activeCourses</h3>
                                </div>
                                <i class="bi bi-journal-text display-6 opacity-50"></i>
                            </div>
                            <a href="/admin/courses" class="stretched-link text-white text-decoration-none small">
                                Manage courses <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm bg-gradient-warning text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-subtitle mb-1 opacity-75">Total Enrollments</h6>
                                    <h3 class="card-title mb-0">@totalEnrollments</h3>
                                </div>
                                <i class="bi bi-clipboard-check display-6 opacity-50"></i>
                            </div>
                            <p class="card-text small mb-0 opacity-75">Across all courses</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm bg-gradient-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-subtitle mb-1 opacity-75">System Health</h6>
                                    <h3 class="card-title mb-0">@systemHealth</h3>
                                </div>
                                <i class="bi bi-heart-pulse display-6 opacity-50"></i>
                            </div>
                            <p class="card-text small mb-0 opacity-75">All systems operational</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- Quick Actions -->
                <div class="col-lg-4 mb-4">
                    <div class="card shadow border-0 h-100">
                        <div class="card-header bg-light py-3">
                            <h5 class="mb-0">
                                <i class="bi bi-lightning me-2"></i>
                                Quick Actions
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                <a href="/admin/users/create" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-plus fs-4 text-primary me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Create New User</h6>
                                            <p class="text-muted small mb-0">Add a student, faculty, or admin account.</p>
                                        </div>
                                    </div>
                                </a>
                                <a href="/admin/courses/create" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-journal-plus fs-4 text-success me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Add New Course</h6>
                                            <p class="text-muted small mb-0">Create a new course and assign faculty.</p>
                                        </div>
                                    </div>
                                </a>
                                <a href="/admin/enrollments" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-clipboard-data fs-4 text-warning me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Manage Enrollments</h6>
                                            <p class="text-muted small mb-0">View and modify student course enrollments.</p>
                                        </div>
                                    </div>
                                </a>
                                <a href="/admin/reports" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-graph-up fs-4 text-info me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Generate Reports</h6>
                                            <p class="text-muted small mb-0">Academic performance and system analytics.</p>
                                        </div>
                                    </div>
                                </a>
                                <a href="/admin/settings" class="list-group-item list-group-item-action border-0 py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-gear fs-4 text-secondary me-3"></i>
                                        <div>
                                            <h6 class="mb-1">System Settings</h6>
                                            <p class="text-muted small mb-0">Configure application parameters and permissions.</p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity Log -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow border-0 h-100">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                            <h5 class="mb-0">
                                <i class="bi bi-clock-history me-2"></i>
                                Recent System Activity
                            </h5>
                            <a href="/admin/audit" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-list-ul me-1"></i> Full Log
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Time</th>
                                            <th>User</th>
                                            <th>Action</th>
                                            <th>Details</th>
                                            <th>IP Address</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>10:45 AM</td>
                                            <td>Dr. Sarah Johnson</td>
                                            <td><span class="badge bg-success">Grade Submitted</span></td>
                                            <td>CS-201 Final grades</td>
                                            <td>192.168.1.105</td>
                                        </tr>
                                        <tr>
                                            <td>09:30 AM</td>
                                            <td>Alice Brown</td>
                                            <td><span class="badge bg-primary">Enrollment</span></td>
                                            <td>Enrolled in CS-284</td>
                                            <td>192.168.1.112</td>
                                        </tr>
                                        <tr>
                                            <td>Yesterday, 4:20 PM</td>
                                            <td>System Admin</td>
                                            <td><span class="badge bg-warning">User Created</span></td>
                                            <td>New faculty: Dr. Emily Williams</td>
                                            <td>192.168.1.1</td>
                                        </tr>
                                        <tr>
                                            <td>Yesterday, 2:15 PM</td>
                                            <td>Bob Smith</td>
                                            <td><span class="badge bg-info">Password Reset</span></td>
                                            <td>Password changed via email</td>
                                            <td>192.168.1.108</td>
                                        </tr>
                                        <tr>
                                            <td>Apr 24, 11:00 AM</td>
                                            <td>Prof. Michael Chen</td>
                                            <td><span class="badge bg-danger">Course Updated</span></td>
                                            <td>CS-301 capacity increased to 25</td>
                                            <td>192.168.1.110</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Alerts -->
            <div class="row mt-4">
                <div class="col">
                    <div class="card shadow border-0 border-start border-3 border-warning">
                        <div class="card-header bg-light py-3">
                            <h5 class="mb-0">
                                <i class="bi bi-exclamation-triangle me-2 text-warning"></i>
                                System Alerts
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="d-flex mb-3">
                                        <i class="bi bi-exclamation-circle text-danger fs-4 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">CS-401 at Full Capacity</h6>
                                            <p class="text-muted small mb-0">Software Engineering course has reached maximum enrollment (10/10). Consider increasing capacity or opening a new section.</p>
                                        </div>
                                    </div>
                                    <div class="d-flex mb-3">
                                        <i class="bi bi-info-circle text-info fs-4 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Backup Scheduled</h6>
                                            <p class="text-muted small mb-0">Automatic database backup is scheduled for tonight at 2:00 AM. Expected downtime: 5 minutes.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex mb-3">
                                        <i class="bi bi-check-circle text-success fs-4 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">Security Scan Completed</h6>
                                            <p class="text-muted small mb-0">No critical vulnerabilities detected in the latest security scan.</p>
                                        </div>
                                    </div>
                                    <div class="d-flex">
                                        <i class="bi bi-clock-history text-primary fs-4 me-3"></i>
                                        <div>
                                            <h6 class="mb-1">License Expiry Reminder</h6>
                                            <p class="text-muted small mb-0">EduConnect enterprise license expires in 45 days. Renew to avoid service interruption.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light py-3 text-end">
                            <a href="/admin/alerts" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-gear me-1"></i> Manage Alerts
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </RoleLayout>
</AuthGuard>

@code {
    private int totalUsers = 0;
    private int activeCourses = 0;
    private int totalEnrollments = 0;
    private string systemHealth = "100%";

    protected override void OnInitialized()
    {
        LoadSystemStats();
    }

    private void LoadSystemStats()
    {
        // Get total users from SeedData (or a proper service)
        var students = StudentService.GetAll().Count;
        var faculty = SeedData.Faculty.Count;
        var admins = 1; // admin from seed
        totalUsers = students + faculty + admins;

        // Get active courses
        var allCourses = CourseService.GetAll();
        activeCourses = allCourses.Count(c => c.IsActive);
        totalEnrollments = allCourses.Sum(c => c.Enrolled.Count);
    }
}