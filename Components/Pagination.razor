@using System.Linq

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mb-0">
        <!-- First Page -->
        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(1)" aria-label="First">
                <i class="bi bi-chevron-double-left"></i>
            </button>
        </li>

        <!-- Previous Page -->
        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(CurrentPage - 1)" aria-label="Previous">
                <i class="bi bi-chevron-left"></i>
            </button>
        </li>

        <!-- Page Numbers -->
        @foreach (var pageNum in GetVisiblePages())
        {
            if (pageNum == -1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
            else
            {
                <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(pageNum)">
                        @pageNum
                    </button>
                </li>
            }
        }

        <!-- Next Page -->
        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(CurrentPage + 1)" aria-label="Next">
                <i class="bi bi-chevron-right"></i>
            </button>
        </li>

        <!-- Last Page -->
        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(TotalPages)" aria-label="Last">
                <i class="bi bi-chevron-double-right"></i>
            </button>
        </li>
    </ul>

    @if (ShowPageSizeSelector)
    {
        <div class="d-flex justify-content-center align-items-center mt-2">
            <span class="text-muted me-2">Show:</span>
            <select class="form-select form-select-sm w-auto" @bind="PageSize" @bind:after="OnPageSizeChangedHandler">
                @foreach (var size in PageSizeOptions)
                {
                    <option value="@size">@size</option>
                }
            </select>
            <span class="text-muted ms-2">per page</span>
        </div>
    }

    @if (ShowInfo)
    {
        <div class="text-center text-muted small mt-2">
            Showing @((CurrentPage - 1) * PageSize + 1) to @Math.Min(CurrentPage * PageSize, TotalItems) of @TotalItems items
            <span class="mx-1">•</span>
            Page @CurrentPage of @TotalPages
        </div>
    }
</nav>

@code {
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    [Parameter]
    public int PageSize { get; set; } = 10;

    [Parameter]
    public int TotalItems { get; set; }

    [Parameter]
    public bool ShowInfo { get; set; } = true;

    [Parameter]
    public bool ShowPageSizeSelector { get; set; } = true;

    [Parameter]
    public List<int> PageSizeOptions { get; set; } = new() { 5, 10, 20, 50 };

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnPageSizeChanged { get; set; }

    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);

    protected override void OnParametersSet()
    {
        // Ensure CurrentPage is within valid range
        if (CurrentPage < 1) CurrentPage = 1;
        if (CurrentPage > TotalPages && TotalPages > 0) CurrentPage = TotalPages;
    }

    private List<int> GetVisiblePages()
    {
        var pages = new List<int>();
        const int maxVisible = 5; // Show at most 5 page numbers

        if (TotalPages <= maxVisible)
        {
            // Show all pages
            for (int i = 1; i <= TotalPages; i++)
                pages.Add(i);
        }
        else
        {
            // Always include first page
            pages.Add(1);

            // Calculate start and end of visible range
            int start = Math.Max(2, CurrentPage - 1);
            int end = Math.Min(TotalPages - 1, CurrentPage + 1);

            // Add ellipsis if needed
            if (start > 2)
                pages.Add(-1); // -1 represents ellipsis

            // Add visible pages
            for (int i = start; i <= end; i++)
                pages.Add(i);

            // Add ellipsis if needed
            if (end < TotalPages - 1)
                pages.Add(-1);

            // Always include last page
            pages.Add(TotalPages);
        }

        return pages;
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage)
            return;

        CurrentPage = page;
        await OnPageChanged.InvokeAsync(page);
    }

    private async Task OnPageSizeChangedHandler()
    {
        // Reset to first page when page size changes
        CurrentPage = 1;
        await OnPageSizeChanged.InvokeAsync(PageSize);
        await OnPageChanged.InvokeAsync(CurrentPage);
    }
}