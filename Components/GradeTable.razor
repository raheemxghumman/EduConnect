@using EduConnect.Models
@if (Grades == null || !Grades.Any())
{
    <div class="alert alert-info mb-0"><i class="bi bi-info-circle"></i><span>No grades available yet.</span></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr><th>Course</th><th class="text-center">Marks</th><th class="text-center">Grade</th><th class="text-center">Credits</th><th class="text-center">Status</th></tr>
            </thead>
            <tbody>
                @foreach (var g in Grades)
                {
                    <tr>
                        <td class="fw-semibold">@g.CourseTitle</td>
                        <td class="text-center">@g.Marks</td>
                        <td class="text-center"><span class="badge @GradeBadge(g.LetterGrade)">@g.LetterGrade</span></td>
                        <td class="text-center">@g.CreditHours</td>
                        <td class="text-center">
                            @if (g.LetterGrade == "F") { <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Fail</span> }
                            else { <span class="badge bg-success"><i class="bi bi-check-circle"></i> Pass</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
@code {
    [Parameter, EditorRequired] public List<GradeRecord> Grades { get; set; } = new();
    static string GradeBadge(string g) => g switch { "A" => "bg-success", "B" => "bg-info", "C" => "bg-warning", "D" => "bg-orange", _ => "bg-danger" };
}
