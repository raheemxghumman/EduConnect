@using EduConnect.Models
@using EduConnect.Services
@inject AuthStateService AuthState
@inject CourseService CourseService
@inject NavigationManager Nav

<div class="card h-100 shadow-sm border-0">
    <div class="card-header bg-light">
        <div class="d-flex justify-content-between align-items-center">
            <h6 class="mb-0 text-primary fw-bold">@Course.Code</h6>
            <StatusBadge Status="@Course.EnrollmentStatus.ToString()" />
        </div>
    </div>
    <div class="card-body">
        <h5 class="card-title">@Course.Title</h5>
        <p class="card-text text-muted small">
            <i class="bi bi-person-badge me-1"></i>
            @Course.AssignedFacultyId
        </p>
        
        <div class="mb-3">
            <span class="badge bg-secondary me-2">
                <i class="bi bi-clock me-1"></i>
                @Course.CreditHours credits
            </span>
            <span class="badge bg-info">
                <i class="bi bi-people me-1"></i>
                @Course.Enrolled.Count / @Course.MaxCapacity enrolled
            </span>
        </div>

        <div class="progress mb-3" style="height: 8px;">
            @{
                var percentage = Course.MaxCapacity > 0 ? (double)Course.Enrolled.Count / Course.MaxCapacity * 100 : 0;
                var progressClass = percentage >= 100 ? "bg-danger" : percentage >= 70 ? "bg-warning" : "bg-success";
            }
            <div class="progress-bar @progressClass" role="progressbar" style="width: @percentage%;"></div>
        </div>
    </div>
    
    <div class="card-footer bg-transparent border-top-0">
        @if (AuthState.State.IsStudent && ShowEnrollButton)
        {
            var isEnrolled = Course.Enrolled.Any(s => s.Id == AuthState.State.CurrentUser?.Id);
            if (isEnrolled)
            {
                <button class="btn btn-outline-success w-100" disabled>
                    <i class="bi bi-check-circle me-1"></i> Enrolled
                </button>
            }
            else if (Course.EnrollmentStatus == EnrollmentStatus.Full)
            {
                <button class="btn btn-outline-secondary w-100" disabled>
                    <i class="bi bi-x-circle me-1"></i> Course Full
                </button>
            }
            else
            {
                <button class="btn btn-primary w-100" @onclick="Enroll">
                    <i class="bi bi-plus-circle me-1"></i> Enroll Now
                </button>
            }
        }
        else if (ShowViewButton)
        {
            <button class="btn btn-outline-primary w-100" @onclick="ViewDetails">
                <i class="bi bi-eye me-1"></i> View Details
            </button>
        }
    </div>
</div>

@code {
    [Parameter]
    public Course Course { get; set; } = default!;

    [Parameter]
    public bool ShowEnrollButton { get; set; } = true;

    [Parameter]
    public bool ShowViewButton { get; set; } = true;

    [Parameter]
    public EventCallback<Course> OnEnroll { get; set; }

    private async Task Enroll()
    {
        if (AuthState.State.CurrentUser?.Id is Guid studentId)
        {
            try
            {
                CourseService.EnrollStudent(Course.Id, studentId);
                await OnEnroll.InvokeAsync(Course);
            }
            catch (Exception ex)
            {
                // In a real app, show error toast
                Console.WriteLine($"Enrollment error: {ex.Message}");
            }
        }
    }

    private void ViewDetails()
    {
        Nav.NavigateTo($"/courses/{Course.Id}");
    }
}